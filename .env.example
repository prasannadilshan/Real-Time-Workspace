# Copy to .env at repo root (apps/api loads via config/env.ts)

NODE_ENV=development

# MongoDB — use Atlas in dev/prod: mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/realtime_editor?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/realtime_editor

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

API_PORT=4000
RT_PORT=4001
WEB_PORT=5173

REDIS_URL=redis://localhost:6379
